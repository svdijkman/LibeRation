$PROBLEM RcppNM bench adv3_trans4 ADVAN=3 TRANS=4
$SUBROUTINE ADVAN3 TRANS4
$INPUT ID TIME DV AMT MDV EVID CMT SS II
$DATA data.csv IGNORE=@
$THETA
 (0.3, 3, 30) ; CL
 (2, 20, 200) ; VC
 (5, 50, 500) ; VP
 (1, 10, 100) ; Q2
$OMEGA
 0.09
 0.09
$SIGMA
 0.1
$PK
CL = THETA(1) * exp(ETA(1))
VC = THETA(2) * exp(ETA(2))
VP = THETA(3)
Q2 = THETA(4)
S1 = VC
S2 = VP
V1 = VC
V2 = VP
Q = Q2
$ERROR
Y = F * (1 + ERR(1))
$EST METHOD=1 INTER MAXEVAL=9999 PRINT=1 NOABORT
$COVAR PRINT=E
]]></nm:control_stream>
